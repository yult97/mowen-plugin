# 火山引擎凭证（从控制台获取）
# 获取地址: https://console.volcengine.com/speech/service/asr
#
# 注意: 只需要填写 API Key 即可
# - VOLC_APP_ID 和 VOLC_RESOURCE_ID 可根据实际情况填写
# - 如果只有一个 API Key，可先将其填入 VOLC_ACCESS_TOKEN 尝试

VOLC_APP_ID=your_app_id
VOLC_ACCESS_TOKEN=your_access_token
# 豆包流式语音识别 2.0（按时长计费）
VOLC_RESOURCE_ID=volc.seedasr.sauc.duration

# 腾讯云凭证（从控制台获取）
# 获取地址: https://console.cloud.tencent.com/cam/capi
TENCENT_APPID=your_appid
TENCENT_SECRET_ID=your_secret_id
TENCENT_SECRET_KEY=your_secret_key
# 引擎模型类型: 16k_zh(普通话), 16k_zh_large(大模型), 16k_en(英语) 等
TENCENT_ENGINE_TYPE=16k_zh

# ASR 提供商：mock（本地模拟）| volcengine（火山引擎）| tencent（腾讯云）
ASR_PROVIDER=mock

# WebSocket 服务配置
WS_HOST=0.0.0.0
WS_PORT=8765

# 重连配置
MAX_RECONNECT=3

# 日志级别
LOG_LEVEL=INFO

# DeepSeek LLM 纠错配置（可选）
# 用于在录音结束后对识别结果进行智能纠错
# 获取 API Key: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-reasoner
ENABLE_LLM_CORRECTION=false

# LLM 纠错速度优化（可选）
# true: 速度优先（更短 prompt、更少上下文）
LLM_FAST_MODE=true
# 单句纠错超时秒数（超时后保留原文，不阻塞后续）
LLM_CORRECTION_TIMEOUT_SEC=3.0
# 小于该长度的 final 句子不触发 LLM（减少碎片调用）
LLM_MIN_TEXT_LEN=5
# 纠错任务积压上限（超过后跳过新任务，保证实时性）
LLM_MAX_PENDING_TASKS=4
# 上下文窗口句数（越小越快）
LLM_MAX_CONTEXT_ITEMS=3
# few-shot 示例数（越小越快）
LLM_FEW_SHOT_COUNT=1
# LLM 输出 token 上限（越小越快）
LLM_MAX_OUTPUT_TOKENS=96

# 语义分段配置（智能段落划分）
# 启用后，系统会根据语义完整性自动划分段落，而不是简单依赖静默检测
ENABLE_SEMANTIC_SEGMENTATION=true
# 最小段落长度（字符数）
SEMANTIC_MIN_SEGMENT_LENGTH=5
# 最大段落长度（字符数）
SEMANTIC_MAX_SEGMENT_LENGTH=150
# 分段置信度阈值（0-1，越高越严格）
SEMANTIC_CONFIDENCE_THRESHOLD=0.7
# 是否启用 BERT 模型（需要额外依赖：transformers torch）
SEMANTIC_ENABLE_BERT=false
