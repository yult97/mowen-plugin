{
  "name": "mowen-note-assistant",
  "version": "0.4.8",
  "description": "墨问笔记助手 - 一键剪藏网页到墨问笔记",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives",
    "typecheck": "tsc --noEmit",
    "test:weixin-regression": "node scripts/verify-weixin-regressions.mjs",
    "test:x-twitter-regression": "node scripts/verify-x-twitter-regressions.mjs",
    "build:zip": "rm -rf dist && npm run build && mkdir -p releases && VERSION=$(node -p \"require('./package.json').version\") && cd dist && zip -r ../releases/mowen-plugin-v$VERSION.zip ."
  },
  "dependencies": {
    "@mozilla/readability": "^0.5.0",
    "dompurify": "^3.0.8",
    "gray-matter": "^4.0.3",
    "html2pdf.js": "^0.14.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.312.0",
    "marked": "^18.0.0",
    "pdf-lib": "^1.17.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.23",
    "@types/chrome": "^0.0.260",
    "@types/dompurify": "^3.0.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  }
}
